	includes <http://example.com/LeaderOntology/description/competenciesDescrip#>
	includes <http://example.com/LeaderOntology/description/decisionProcessDescrip#>
	includes <http://example.com/LeaderOntology/description/impactsDescrip#>
	includes <http://example.com/LeaderOntology/description/leaderstyleDescrip#>
	includes <http://example.com/LeaderOntology/description/strategiesDescrip#>
	includes <http://example.com/LeaderOntology/description/toolsDescrip#>
	uses <http://example.com/LeaderOntology/vocabulary/bundle#>
	
}